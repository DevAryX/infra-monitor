# Example environment variables for infra-monitor
# Copy these into ~/.infra-monitor.env and adjust values for your machine/server.

export INFRA_MONITOR_HOME="$HOME/infra-monitor"
export INFRA_MONITOR_LOG_DIR="$HOME/infra-monitor/logs"
export INFRA_MONITOR_SYSTEM_LOG="$HOME/infra-monitor/logs/system_report.log"
export INFRA_MONITOR_ERROR_LOG="$HOME/infra-monitor/logs/error.log"

export INFRA_MONITOR_CPU_THRESHOLD="80"
export INFRA_MONITOR_MEMORY_THRESHOLD="80"
export INFRA_MONITOR_DISK_THRESHOLD="85"
export INFRA_MONITOR_MAX_LOG_SIZE="50000"

# Optional if using S3 uploads
export INFRA_MONITOR_S3_BUCKET="your-bucket-name"
export INFRA_MONITOR_S3_KEY="system_report.log"
